{
  "name": "tangle",
  "private": true,
  "version": "0.1.0",
  "description": "Phaser 4 + React + Capacitor game template.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src scripts",
    "format": "prettier --write .",
    "test:e2e": "playwright test",
    "rename": "tsx scripts/rename-app.ts",
    "generate-levels": "tsx scripts/generate-levels.ts",
    "cap:sync": "npm run build && npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:run:ios": "npm run build && npx cap sync ios && npx cap run ios",
    "cap:run:android": "npm run build && npx cap sync android && npx cap run android"
  },
  "dependencies": {
    "@capacitor-community/keep-awake": "^8.0.1",
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/screen-orientation": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@fontsource-variable/fraunces": "^5.1.0",
    "@fontsource/geist": "^5.1.0",
    "@fontsource/geist-mono": "^5.1.0",
    "d3-delaunay": "^6.0.4",
    "phaser": "4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.1",
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.59.1",
    "@types/d3-delaunay": "^6.0.4",
    "@types/node": "22.19.17",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "3.2.4",
    "autoprefixer": "10.5.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "25.0.1",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "tailwindcss": "3.4.19",
    "terser": "^5.28.1",
    "tsx": "4.21.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.3.1",
    "vitest": "3.2.4"
  }
}
